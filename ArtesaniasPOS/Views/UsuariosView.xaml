<UserControl x:Class="ArtesaniasPOS.UI.Views.Configuracion.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Command="{Binding NuevoCommand}" Cursor="Hand" Margin="0,0,6,0">
                    <Button.Style><Style TargetType="Button"><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8" Padding="14,8">
                                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/><GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush></Border.Background>
                                <TextBlock Text="＋ Nuevo usuario" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/></Trigger></ControlTemplate.Triggers>
                        </ControlTemplate></Setter.Value></Setter></Style></Button.Style></Button>
                <Button Command="{Binding EditarCommand}" Cursor="Hand" Margin="0,0,6,0">
                    <Button.Style><Style TargetType="Button"><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8" Padding="14,8" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                                <TextBlock Text="✏️ Editar" FontSize="12" Foreground="#2563EB"/></Border>
                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/></Trigger></ControlTemplate.Triggers>
                        </ControlTemplate></Setter.Value></Setter></Style></Button.Style></Button>
                <Button Command="{Binding EliminarCommand}" Cursor="Hand">
                    <Button.Style><Style TargetType="Button"><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8" Padding="14,8" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1">
                                <TextBlock Text="🗑️ Desactivar" FontSize="12" Foreground="#DC2626"/></Border>
                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/></Trigger></ControlTemplate.Triggers>
                        </ControlTemplate></Setter.Value></Setter></Style></Button.Style></Button>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Usuarios}" SelectedItem="{Binding Seleccionado}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6" BorderThickness="0" Background="Transparent"
                          RowBackground="White" AlternatingRowBackground="#FAFBFC" FontSize="12" SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB"/><Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="12,8"/><Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/></Style></DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle><Style TargetType="DataGridCell"><Setter Property="Padding" Value="12,6"/>
                        <Setter Property="BorderThickness" Value="0"/><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="DataGridCell"><Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style></DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="120"/>
                        <DataGridTextColumn Header="Perfil" Binding="{Binding PerfilNombre}" Width="100"/>
                        <DataGridTemplateColumn Header="Estado" Width="80">
                            <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                    <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#FEE2E2"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding Activo}" Value="True">
                                            <Setter Property="Background" Value="#D1FAE5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Inactivo"/><Setter Property="Foreground" Value="#DC2626"/>
                                            <Style.Triggers><DataTrigger Binding="{Binding Activo}" Value="True">
                                                <Setter Property="Text" Value="Activo"/><Setter Property="Foreground" Value="#059669"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock></Border>
                            </DataTemplate></DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Panel formulario -->
        <Border Grid.Column="1" Width="300" Background="White" CornerRadius="10"
                BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="15,0,0,0"
                Visibility="{Binding FormularioVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding TituloFormulario}" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                <TextBlock Text="Nombre *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="13" Margin="0,0,0,12">
                    <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/>
                        <Setter Property="BorderThickness" Value="1.5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style></TextBox.Style></TextBox>

                <TextBlock Text="Usuario *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="13" Margin="0,0,0,12">
                    <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/>
                        <Setter Property="BorderThickness" Value="1.5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style></TextBox.Style></TextBox>

                <TextBlock Text="Contraseña" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="13" Margin="0,0,0,12">
                    <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/>
                        <Setter Property="BorderThickness" Value="1.5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style></TextBox.Style></TextBox>

                <TextBlock Text="Perfil *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Perfiles}" SelectedItem="{Binding PerfilSeleccionado}" DisplayMemberPath="Nombre" Padding="10,8" FontSize="13" Margin="0,0,0,15">
                    <ComboBox.Style><Style TargetType="ComboBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1.5"/></Style></ComboBox.Style></ComboBox>

                <Border Background="#FEE2E2" CornerRadius="8" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding MensajeError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding MensajeError}" FontSize="11" Foreground="#DC2626" TextWrapping="Wrap"/></Border>
                <Border Background="#D1FAE5" CornerRadius="8" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding MensajeExito, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding MensajeExito}" FontSize="11" Foreground="#059669"/></Border>

                <Button Command="{Binding GuardarCommand}" Cursor="Hand" Margin="0,0,0,8">
                    <Button.Style><Style TargetType="Button"><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8" Padding="12,10">
                                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/><GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush></Border.Background>
                                <TextBlock Text="💾 Guardar" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/></Border>
                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/></Trigger></ControlTemplate.Triggers>
                        </ControlTemplate></Setter.Value></Setter></Style></Button.Style></Button>
                <Button Command="{Binding CancelarCommand}" Cursor="Hand">
                    <Button.Style><Style TargetType="Button"><Setter Property="Template"><Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8" Padding="12,10" Background="White" BorderBrush="#D1D5DB" BorderThickness="1.5">
                                <TextBlock Text="Cancelar" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/></Border>
                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/></Trigger></ControlTemplate.Triggers>
                        </ControlTemplate></Setter.Value></Setter></Style></Button.Style></Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
