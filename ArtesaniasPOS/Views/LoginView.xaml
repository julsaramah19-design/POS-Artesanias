<UserControl x:Class="ArtesaniasPOS.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Panel izquierdo decorativo -->
            <ColumnDefinition Width="1.2*"/>
            <!-- Panel derecho con formulario -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: branding -->
        <Border Grid.Column="0" CornerRadius="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3B82F6" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">

                <!-- Ícono -->
                <Border Width="90" Height="90" CornerRadius="20"
                        Background="#FFFFFF20"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,25">
                    <TextBlock Text="🛍️" FontSize="42"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="ArtesaniasPOS"
                           FontSize="32" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding NombreNegocio}"
                           FontSize="16"
                           Foreground="#FFFFFFCC"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Tu sistema de ventas&#x0a;rápido, fácil y confiable."
                           FontSize="14"
                           Foreground="#FFFFFF99"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Panel derecho: formulario de login -->
        <Grid Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center"
                        MaxWidth="320"
                        Margin="40,0">

                <TextBlock Text="Iniciar sesión"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Ingresa tus credenciales para continuar"
                           FontSize="13" Foreground="#6B7280"
                           Margin="0,0,0,30"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="50">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,18,0,6"/>
                <PasswordBox x:Name="PasswordField"
                             Padding="12,10" FontSize="14"
                             MaxLength="50"
                             PasswordChanged="OnPasswordChanged">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- Mensaje de error -->
                <Border Background="#FEE2E2" CornerRadius="8"
                        Padding="12" Margin="0,18,0,0"
                        Visibility="{Binding MensajeError, 
                            Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding MensajeError}"
                               FontSize="12" Foreground="#DC2626"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Botón login -->
                <Button Content="Entrar"
                        Command="{Binding LoginCommand}"
                        Padding="14,12"
                        FontSize="15" FontWeight="SemiBold"
                        Margin="0,22,0,0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Loading -->
                <TextBlock Text="Verificando..."
                           FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="{Binding IsLoading, 
                               Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
