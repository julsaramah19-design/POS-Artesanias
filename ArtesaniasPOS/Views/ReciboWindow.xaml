<Window x:Class="ArtesaniasPOS.UI.Views.Ventas.ReciboWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recibo de Venta"
        Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Contenido del recibo (imprimible) -->
        <Border x:Name="ReciboContent" Grid.Row="0" Padding="20,15" Background="White">
            <StackPanel>
                <!-- Encabezado -->
                <TextBlock Text="{Binding NombreNegocio}" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1F2937"/>
                <TextBlock Text="================================"
                           FontFamily="Consolas" FontSize="11" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,4,0,4"/>

                <!-- Info venta -->
                <StackPanel Margin="0,0,0,6">
                    <Grid>
                        <TextBlock Text="Venta #:" FontSize="11" Foreground="#6B7280" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding VentaId}" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Fecha:" FontSize="11" Foreground="#6B7280" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding FechaFormateada}" FontSize="11"
                                   FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Vendedor:" FontSize="11" Foreground="#6B7280" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding Vendedor}" FontSize="11"
                                   FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Pago:" FontSize="11" Foreground="#6B7280" FontFamily="Consolas"/>
                        <TextBlock Text="{Binding MedioPago}" FontSize="11"
                                   FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="--------------------------------"
                           FontFamily="Consolas" FontSize="11" Foreground="#D1D5DB"
                           HorizontalAlignment="Center"/>

                <!-- Detalle productos -->
                <ItemsControl ItemsSource="{Binding Items}" Margin="0,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,3">
                                <Grid>
                                    <TextBlock FontSize="11" FontFamily="Consolas" Foreground="#1F2937"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Cantidad, Mode=OneWay}"/>
                                        <Run Text="x"/>
                                        <Run Text="{Binding Nombre, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Subtotal, StringFormat='${0:N0}'}"
                                               FontSize="11" FontFamily="Consolas"
                                               HorizontalAlignment="Right" Foreground="#1F2937"/>
                                </Grid>
                                <Grid Visibility="{Binding TieneDescuento, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Margin="15,0,0,0">
                                    <TextBlock Text="  Desc:" FontSize="10" FontFamily="Consolas" Foreground="#DC2626"/>
                                    <TextBlock Text="{Binding Descuento, StringFormat='-${0:N0}'}"
                                               FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" Foreground="#DC2626"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="--------------------------------"
                           FontFamily="Consolas" FontSize="11" Foreground="#D1D5DB"
                           HorizontalAlignment="Center"/>

                <!-- Totales -->
                <StackPanel Margin="0,6,0,0">
                    <Grid>
                        <TextBlock Text="Subtotal:" FontSize="11" FontFamily="Consolas" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding Subtotal, StringFormat='${0:N0}'}"
                                   FontSize="11" FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <TextBlock Text="TOTAL:" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Foreground="#1F2937"/>
                        <TextBlock Text="{Binding Total, StringFormat='${0:N0}'}"
                                   FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                                   HorizontalAlignment="Right" Foreground="#1F2937"/>
                    </Grid>
                    <TextBlock Text="--------------------------------"
                               FontFamily="Consolas" FontSize="11" Foreground="#D1D5DB"
                               HorizontalAlignment="Center" Margin="0,4"/>
                    <Grid>
                        <TextBlock Text="Pagó:" FontSize="11" FontFamily="Consolas" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding MontoPagado, StringFormat='${0:N0}'}"
                                   FontSize="11" FontFamily="Consolas" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Cambio:" FontSize="11" FontFamily="Consolas" Foreground="#059669" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Cambio, StringFormat='${0:N0}'}"
                                   FontSize="11" FontFamily="Consolas" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Foreground="#059669"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="================================"
                           FontFamily="Consolas" FontSize="11" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <TextBlock Text="¡Gracias por su compra!"
                           FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="#6B7280"/>
            </StackPanel>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,15">
            <Button Content="🖨️ Imprimir" Click="OnImprimir" Cursor="Hand" Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="20,10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                <GradientStop Color="#8B5CF6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Cerrar" Click="OnCerrar" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="20,10"
                                            Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>