<UserControl x:Class="ArtesaniasPOS.Views.Wizard.BusinessInfoStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="700">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel MaxWidth="520" Margin="40,20"
                        HorizontalAlignment="Center">

                <!-- Título del paso -->
                <TextBlock Text="🏪 Datos de tu negocio"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Esta información aparecerá en tus facturas y recibos."
                           FontSize="13" Foreground="#6B7280"
                           Margin="0,0,0,25"/>

                <!-- Nombre del negocio (obligatorio) -->
                <TextBlock Text="Nombre del negocio *"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NombreNegocio, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="100">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- NIT -->
                <TextBlock Text="NIT / Cédula"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>
                <TextBox Text="{Binding NIT, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="20">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Teléfono y Email en fila -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Teléfono"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,10" FontSize="14"
                                 MaxLength="15">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,10" FontSize="14"
                                 MaxLength="100">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>

                <!-- Dirección -->
                <TextBlock Text="Dirección"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>
                <TextBox Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="200">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Logo -->
                <TextBlock Text="Logo del negocio"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>

                <Border BorderBrush="#D1D5DB" BorderThickness="1.5"
                        CornerRadius="8" Background="#F9FAFB"
                        Padding="15" Cursor="Hand"
                        x:Name="LogoDropArea">

                    <StackPanel HorizontalAlignment="Center">
                        <!-- Preview del logo si existe -->
                        <Image x:Name="LogoPreview"
                               MaxHeight="80" MaxWidth="200"
                               Margin="0,0,0,10"
                               Visibility="Collapsed"/>

                        <TextBlock Text="📷 Click para seleccionar logo"
                                   FontSize="13" Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="PNG, JPG — máximo 2MB"
                                   FontSize="11" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SeleccionarLogoCommand}"/>
                    </Border.InputBindings>
                </Border>

                <!-- Indicador de pasos -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,5">
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#3B82F6" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#E5E7EB" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#E5E7EB" Margin="4,0"/>
                </StackPanel>
                <TextBlock Text="Paso 2 de 4 — Tu negocio"
                           FontSize="12" Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
