<UserControl x:Class="ArtesaniasPOS.Views.Wizard.AdminUserStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="700">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel MaxWidth="520" Margin="40,20"
                        HorizontalAlignment="Center">

                <!-- Título -->
                <TextBlock Text="🔐 Usuario administrador"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Configura tus credenciales de acceso al sistema."
                           FontSize="13" Foreground="#6B7280"
                           Margin="0,0,0,25"/>

                <!-- Aviso de seguridad -->
                <Border Background="#FEF3C7" CornerRadius="8"
                        Padding="12" Margin="0,0,0,20">
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="#92400E">
                        <Run FontWeight="SemiBold">⚠️ Importante:</Run>
                        <Run> Cambia las credenciales por defecto para proteger tu negocio.</Run>
                    </TextBlock>
                </Border>

                <!-- Nombre completo -->
                <TextBlock Text="Nombre completo *"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="100">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Nombre de usuario -->
                <TextBlock Text="Nombre de usuario *"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>
                <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,10" FontSize="14"
                         MaxLength="50">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña * (mínimo 6 caracteres)"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>
                <PasswordBox x:Name="PasswordField"
                             Padding="12,10" FontSize="14"
                             MaxLength="50"
                             PasswordChanged="OnPasswordChanged">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- Confirmar contraseña -->
                <TextBlock Text="Confirmar contraseña *"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,16,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordField"
                             Padding="12,10" FontSize="14"
                             MaxLength="50"
                             PasswordChanged="OnConfirmPasswordChanged">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- Indicador de coincidencia -->
                <TextBlock x:Name="PasswordMatchIndicator"
                           FontSize="12" Margin="0,8,0,0"
                           Visibility="Collapsed"/>

                <!-- Mensaje de error -->
                <Border x:Name="ErrorBorder"
                        Background="#FEE2E2" CornerRadius="8"
                        Padding="12" Margin="0,15,0,0"
                        Visibility="{Binding MensajeError, 
                            Converter={StaticResource StringToVisibilityConverter},
                            FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding MensajeError}"
                               FontSize="12" Foreground="#DC2626"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Indicador de pasos -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,5">
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#3B82F6" Margin="4,0"/>
                </StackPanel>
                <TextBlock Text="Paso 4 de 4 — Último paso"
                           FontSize="12" Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
