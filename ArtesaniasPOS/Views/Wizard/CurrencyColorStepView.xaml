<UserControl x:Class="ArtesaniasPOS.Views.Wizard.CurrencyColorStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="700">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel MaxWidth="520" Margin="40,20"
                        HorizontalAlignment="Center">

                <!-- Título -->
                <TextBlock Text="🎨 Moneda y personalización"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Elige tu moneda principal y dale color a tu sistema."
                           FontSize="13" Foreground="#6B7280"
                           Margin="0,0,0,25"/>

                <!-- Moneda base -->
                <TextBlock Text="Moneda principal"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6"/>

                <ComboBox ItemsSource="{Binding Monedas}"
                          SelectedItem="{Binding MonedaSeleccionada}"
                          DisplayMemberPath="DisplayText"
                          Padding="12,10" FontSize="14"
                          Margin="0,0,0,10">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <Border Background="#EFF6FF" CornerRadius="8"
                        Padding="12" Margin="0,0,0,25">
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="#1E40AF">
                        <Run FontWeight="SemiBold">💡 Tip:</Run>
                        <Run> La moneda base es en la que registras tus precios. Las demás monedas se convertirán automáticamente.</Run>
                    </TextBlock>
                </Border>

                <!-- Color primario -->
                <TextBlock Text="Color principal de la app"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,10"/>

                <ItemsControl ItemsSource="{Binding ColoresPredefinidos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="44" Height="44"
                                    CornerRadius="22"
                                    Margin="4" Cursor="Hand"
                                    BorderThickness="3"
                                    x:Name="ColorBorder"
                                    MouseLeftButtonUp="OnColorPrimarioClick">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding}"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="Transparent"/>
                                </Border.BorderBrush>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Preview del color seleccionado -->
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="Color seleccionado: "
                               FontSize="13" Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                    <Border Width="28" Height="28" CornerRadius="6"
                            Margin="8,0,8,0"
                            x:Name="PrimaryColorPreview">
                        <Border.Background>
                            <SolidColorBrush x:Name="PrimaryColorBrush" Color="#3B82F6"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="{Binding ColorPrimario}"
                               FontSize="13" Foreground="#374151"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Color secundario -->
                <TextBlock Text="Color secundario"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,25,0,10"/>

                <ItemsControl ItemsSource="{Binding ColoresPredefinidos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="44" Height="44"
                                    CornerRadius="22"
                                    Margin="4" Cursor="Hand"
                                    BorderThickness="3"
                                    MouseLeftButtonUp="OnColorSecundarioClick">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding}"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="Transparent"/>
                                </Border.BorderBrush>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="Color seleccionado: "
                               FontSize="13" Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                    <Border Width="28" Height="28" CornerRadius="6"
                            Margin="8,0,8,0"
                            x:Name="SecondaryColorPreview">
                        <Border.Background>
                            <SolidColorBrush x:Name="SecondaryColorBrush" Color="#1E40AF"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="{Binding ColorSecundario}"
                               FontSize="13" Foreground="#374151"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Indicador de pasos -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,30,0,5">
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#10B981" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#3B82F6" Margin="4,0"/>
                    <Border Width="50" Height="6" CornerRadius="3"
                            Background="#E5E7EB" Margin="4,0"/>
                </StackPanel>
                <TextBlock Text="Paso 3 de 4 — Personalización"
                           FontSize="12" Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
