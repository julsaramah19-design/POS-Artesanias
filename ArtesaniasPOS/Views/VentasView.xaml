<UserControl x:Class="ArtesaniasPOS.UI.Views.Ventas.VentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="650" d:DesignWidth="950"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER + BUSQUEDA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="&#x1F4B0; Punto de Venta" FontSize="24" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,12"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" Padding="14,11" FontSize="14">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                                <TextBlock Text="&#x1F50D; Escanear codigo o buscar producto..." FontSize="14" Foreground="#9CA3AF" Margin="16,11,0,0" IsHitTestVisible="False" Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StringToVisibilityInvertedConverter}}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding BuscarCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="2" Command="{Binding BuscarCommand}" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SB" CornerRadius="10" Padding="18,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="Buscar" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="SB" Property="Opacity" Value="0.9"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>

        <!-- RESULTADOS + CARRITO -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- Resultados -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Resultados" FontSize="13" FontWeight="SemiBold" Foreground="#6B7280" Margin="15,12,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ResultadosBusqueda}" SelectedItem="{Binding ProductoSeleccionado}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="IB" Padding="15,10" Cursor="Hand" Background="Transparent" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="IB" Property="Background" Value="#F0F9FF"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="IB" Property="Background" Value="#EFF6FF"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Nombre}" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding CodigoBarras}" FontSize="11" Foreground="#9CA3AF" FontFamily="Consolas"/>
                                            <TextBlock Text=" · Stock: " FontSize="11" Foreground="#9CA3AF"/>
                                            <TextBlock Text="{Binding StockActual}" FontSize="11" Foreground="#059669" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding PrecioBase, StringFormat='${0:N0}'}" FontSize="15" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Boton agregar -->
            <Button Grid.Column="1" Command="{Binding AgregarAlCarritoCommand}" VerticalAlignment="Center" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="AB" Width="32" Height="32" CornerRadius="16" Background="#3B82F6">
                                        <TextBlock Text="&#x2192;" FontSize="16" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="AB" Property="Opacity" Value="0.85"/></Trigger>
                                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="AB" Property="Opacity" Value="0.3"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Carrito -->
            <Border Grid.Column="2" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="15,12,15,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F6D2; Carrito" FontSize="14" FontWeight="Bold" Foreground="#1F2937"/>
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CantidadItems}" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding LimpiarCarritoCommand}" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock x:Name="CT" Text="Limpiar" FontSize="12" Foreground="#9CA3AF"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CT" Property="Foreground" Value="#EF4444"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Carrito}">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter/></ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="15,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="SemiBold" Foreground="#1F2937" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding PrecioUnitario, StringFormat='${0:N0} c/u'}" FontSize="11" Foreground="#9CA3AF"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" Width="45" Padding="4" FontSize="13" TextAlignment="Center" FontWeight="SemiBold" Margin="10,0">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:N0}'}" FontSize="13" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button Grid.Column="3" Command="{Binding DataContext.QuitarDelCarritoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Cursor="Hand" VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="RB" Width="24" Height="24" CornerRadius="12" Background="#FEF2F2">
                                                                    <TextBlock Text="&#x2715;" FontSize="10" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="RB" Property="Background" Value="#FEE2E2"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Grid.Row="2" Background="#F9FAFB" Padding="15,10" CornerRadius="0,0,10,10" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock Text="Subtotal" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding SubtotalCarrito, StringFormat='${0:N0}'}" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- RESUMEN PAGO -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Moneda" FontSize="11" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Monedas}" SelectedItem="{Binding MonedaSeleccionada}" DisplayMemberPath="DisplayText" Padding="8,7" FontSize="12">
                                <ComboBox.Style><Style TargetType="ComboBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/></Style></ComboBox.Style>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Medio de pago" FontSize="11" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding MediosPago}" SelectedItem="{Binding MedioPagoSeleccionado}" DisplayMemberPath="Nombre" Padding="8,7" FontSize="12">
                                <ComboBox.Style><Style TargetType="ComboBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/></Style></ComboBox.Style>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="Descuento" FontSize="11" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Descuento, UpdateSourceTrigger=PropertyChanged}" Padding="8,7" FontSize="12">
                            <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"><ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style></TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,20,0">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Monto pagado" FontSize="11" Foreground="#6B7280" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MontoPagado, UpdateSourceTrigger=PropertyChanged}" Padding="10,9" FontSize="15" FontWeight="SemiBold">
                            <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="#F0FDF4"/><Setter Property="BorderBrush" Value="#86EFAC"/><Setter Property="BorderThickness" Value="2"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"><ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style></TextBox.Style>
                        </TextBox>
                    </StackPanel>
                    <Border Background="#FEF3C7" CornerRadius="8" Padding="12,8">
                        <Grid>
                            <TextBlock Text="Cambio:" FontSize="13" Foreground="#92400E"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SimboloMoneda}" FontSize="16" FontWeight="Bold" Foreground="#92400E"/>
                                <TextBlock Text="{Binding Cambio, StringFormat='{}{0:N2}'}" FontSize="16" FontWeight="Bold" Foreground="#92400E"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="180">
                    <Border Background="#EFF6FF" CornerRadius="10" Padding="18,12" Margin="0,0,0,10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="TOTAL" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SimboloMoneda}" FontSize="26" FontWeight="Bold" Foreground="#1E40AF" VerticalAlignment="Bottom" Margin="0,0,3,2"/>
                                <TextBlock Text="{Binding TotalEnMoneda, StringFormat='{}{0:N2}'}" FontSize="28" FontWeight="Bold" Foreground="#1E40AF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,0,5" Visibility="{Binding MensajeError, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding MensajeError}" FontSize="11" Foreground="#DC2626" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Border Margin="0,0,0,5" Visibility="{Binding MensajeExito, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding MensajeExito}" FontSize="11" Foreground="#059669" TextWrapping="Wrap" TextAlignment="Center" FontWeight="SemiBold"/>
                    </Border>
                    <Button Command="{Binding ConfirmarVentaCommand}" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CB" CornerRadius="10" Padding="20,12">
                                                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#10B981" Offset="0"/><GradientStop Color="#059669" Offset="1"/></LinearGradientBrush></Border.Background>
                                                <TextBlock Text="&#x2705; Confirmar venta" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CB" Property="Opacity" Value="0.9"/></Trigger>
                                                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="CB" Property="Opacity" Value="0.4"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
