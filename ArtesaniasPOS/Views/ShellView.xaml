<UserControl x:Class="ArtesaniasPOS.UI.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ArtesaniasPOS.Core.ViewModels;assembly=ArtesaniasPOS.Core"
             xmlns:prodVm="clr-namespace:ArtesaniasPOS.Core.ViewModels.Productos;assembly=ArtesaniasPOS.Core"
             xmlns:prodViews="clr-namespace:ArtesaniasPOS.UI.Views.Productos"
             xmlns:ventasVm="clr-namespace:ArtesaniasPOS.Core.ViewModels.Ventas;assembly=ArtesaniasPOS.Core"
             xmlns:ventasViews="clr-namespace:ArtesaniasPOS.UI.Views.Ventas"
             xmlns:reportesVm="clr-namespace:ArtesaniasPOS.Core.ViewModels.Reportes;assembly=ArtesaniasPOS.Core"
             xmlns:reportesViews="clr-namespace:ArtesaniasPOS.UI.Views.Reportes"
             xmlns:configVm="clr-namespace:ArtesaniasPOS.Core.ViewModels.Configuracion;assembly=ArtesaniasPOS.Core"
             xmlns:configViews="clr-namespace:ArtesaniasPOS.UI.Views.Configuracion"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <!-- DataTemplate para el placeholder de módulos -->
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="{Binding Icono}"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>
                <TextBlock Text="{Binding Titulo}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#1F2937"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Mensaje}"
                           FontSize="14" Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type prodVm:ProductosViewModel}">
            <prodViews:ProductosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type ventasVm:VentasViewModel}">
            <ventasViews:VentasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type reportesVm:ReportesViewModel}">
            <reportesViews:ReportesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type configVm:ConfiguracionContainerViewModel}">
            <configViews:ConfiguracionContainerView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="250"/>
            <!-- Contenido principal -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0"
                x:Name="SidebarBorder">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="SidebarGradientStart" Color="#3B82F6" Offset="0"/>
                    <GradientStop x:Name="SidebarGradientEnd" Color="#1E40AF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Logo y nombre -->
                    <RowDefinition Height="Auto"/>
                    <!-- Menú -->
                    <RowDefinition Height="*"/>
                    <!-- Usuario y cerrar sesión -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header del sidebar: nombre del negocio -->
                <StackPanel Grid.Row="0" Margin="20,25,20,25">
                    <TextBlock Text="🛍️" FontSize="28"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding NombreNegocio}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Separador -->
                <Border Grid.Row="0"
                        VerticalAlignment="Bottom"
                        Height="1" Background="#FFFFFF30"
                        Margin="20,0"/>

                <!-- Menú de navegación -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding MenuItems}"
                         SelectedItem="{Binding MenuSeleccionado}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="10,15,10,0">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                CornerRadius="10"
                                                Padding="14,11"
                                                Margin="0,2"
                                                Cursor="Hand"
                                                Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder"
                                                        Property="Background"
                                                        Value="#FFFFFF18"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder"
                                                        Property="Background"
                                                        Value="#FFFFFF25"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icono}"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding Titulo}"
                                           FontSize="14"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer: usuario logueado + cerrar sesión -->
                <Border Grid.Row="2" Margin="10,0,10,15">
                    <!-- Separador -->
                    <StackPanel>
                        <Border Height="1" Background="#FFFFFF30"
                                Margin="10,0,10,12"/>

                        <!-- Info del usuario -->
                        <Grid Margin="10,0,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar circular con inicial -->
                            <Border Grid.Column="0"
                                    Width="38" Height="38"
                                    CornerRadius="19"
                                    Background="#FFFFFF30"
                                    Margin="0,0,12,0">
                                <TextBlock Text="{Binding InicialUsuario}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding NombreUsuario}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding PerfilNombre}"
                                           FontSize="11"
                                           Foreground="#FFFFFF99"/>
                            </StackPanel>
                        </Grid>

                        <!-- Botón cerrar sesión -->
                        <Button Command="{Binding CerrarSesionCommand}"
                                Cursor="Hand"
                                Margin="5,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="LogoutBorder"
                                                        CornerRadius="8"
                                                        Padding="12,8"
                                                        Background="#FFFFFF10">
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="🚪" FontSize="14"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Cerrar sesión"
                                                                   FontSize="12"
                                                                   Foreground="#FFFFFFCC"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="LogoutBorder"
                                                                Property="Background"
                                                                Value="#FFFFFF20"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ==================== CONTENIDO PRINCIPAL ==================== -->
        <Grid Grid.Column="1" Background="#F3F4F6">
            <ContentControl Content="{Binding ContenidoActual}"
                            Margin="0"/>
        </Grid>
    </Grid>
</UserControl>
