<Window x:Class="ArtesaniasPOS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Artesanías POS"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Sistema de Ventas - Artesanías"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <!-- Buttons -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Vender" FontSize="18" Margin="10" Height="80"/>
            <Button Content="Productos" FontSize="18" Margin="10" Height="80"/>
            <Button Content="Stock" FontSize="18" Margin="10" Height="80"/>
            <Button Content="Salir" FontSize="18" Margin="10" Height="80"/>
        </UniformGrid>
    </Grid>
</Window>
