<Window x:Class="ArtesaniasPOS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wizard="clr-namespace:ArtesaniasPOS.Views.Wizard"
        xmlns:views="clr-namespace:ArtesaniasPOS.UI.Views"
        Title="ArtesaniasPOS" 
        Height="650" Width="950"
        MinHeight="550" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid>
        <!-- Wizard: primer arranque -->
        <wizard:WizardContainerView x:Name="WizardContainer"
                                     Visibility="Collapsed"/>

        <!-- Login -->
        <views:LoginView x:Name="LoginContainer"
                          Visibility="Collapsed"/>

        <!-- Shell principal (sidebar + contenido) -->
        <views:ShellView x:Name="ShellContainer"
                          Visibility="Collapsed"/>

        <!-- Loading inicial -->
        <StackPanel x:Name="LoadingPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="Cargando..."
                       FontSize="16" Foreground="#6B7280"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
